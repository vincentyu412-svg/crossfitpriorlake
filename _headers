# Cache static images for 1 year
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache CSS for 1 year (file is versioned/minified)
/css/*
  Cache-Control: public, max-age=31536000, immutable

# Cache JS for 1 year
/js/*
  Cache-Control: public, max-age=31536000, immutable

# Cache favicons and manifest
/site.webmanifest
  Cache-Control: public, max-age=31536000, immutable
